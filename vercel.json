{
  "functions": {
    "api/refresh-cache.mjs": {
      "maxDuration": 300
    },
    "api/discord.mjs": {
      "maxDuration": 60
    },
    "api/projects.mjs": {
      "maxDuration": 30
    },
    "api/plugin-claim.mjs": {
      "maxDuration": 15
    },
    "api/plugin-craftable.mjs": {
      "maxDuration": 30
    },
    "api/plugin-items.mjs": {
      "maxDuration": 15
    },
    "api/plugin-item-sources.mjs": {
      "maxDuration": 30
    },
    "api/plugin-craft-breakdown.mjs": {
      "maxDuration": 30
    },
    "api/plugin-trading-query.mjs": {
      "maxDuration": 60
    },
    "api/plugin-cleanup.mjs": {
      "maxDuration": 60
    },
    "api/plugin-projects.mjs": {
      "maxDuration": 30
    },
    "api/auth.mjs": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/api/projects/:id", "destination": "/api/projects" },
    { "source": "/api/lists/:id", "destination": "/api/projects" },
    { "source": "/api/lists", "destination": "/api/projects" },
    { "source": "/api/auth/admin/(.*)", "destination": "/api/auth" },
    { "source": "/api/auth/:action", "destination": "/api/auth" },
    { "source": "/api/plugin/claim", "destination": "/api/plugin-claim" },
    { "source": "/api/plugin/craftable", "destination": "/api/plugin-craftable" },
    { "source": "/api/plugin/items", "destination": "/api/plugin-items" },
    { "source": "/api/plugin/item-sources", "destination": "/api/plugin-item-sources" },
    { "source": "/api/plugin/craft-breakdown", "destination": "/api/plugin-craft-breakdown" },
    { "source": "/api/plugin/trading/query", "destination": "/api/plugin-trading-query" },
    { "source": "/api/plugin/cleanup", "destination": "/api/plugin-cleanup" },
    { "source": "/api/plugin/projects/:id", "destination": "/api/plugin-projects" },
    { "source": "/api/plugin/projects", "destination": "/api/plugin-projects" },
    { "source": "/((?!api/|@|src/|node_modules/|.*\\.).*)", "destination": "/" }
  ]
}
